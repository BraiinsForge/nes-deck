#!/bin/sh

# Root launcher for the persistent Deck menu installation.  All paths are
# fixed, all expansions are quoted, and catalog data is never evaluated by a
# shell.  ECL reads it with Common Lisp reader evaluation disabled.

set -u

PATH=/usr/sbin:/usr/bin:/sbin:/bin
LC_ALL=C
BASE=/mnt/data/nes-deck
MENU_DIR=$BASE/menu
STATE_DIR=$BASE/state
LOG_DIR=$BASE/log
TMP_DIR=$STATE_DIR/tmp
TMPDIR=$TMP_DIR
MENU=$MENU_DIR/deck-menu
NES_EMULATOR=$BASE/infones
GB_EMULATOR=$BASE/gb-deck
CHIP8_EMULATOR=$BASE/chip8-deck
DECK_GAME=$BASE/ten-seconds-deck
CATALOG=$MENU_DIR/games.sexp
FALLBACK_MANIFEST=$MENU_DIR/games.tsv
GENERATED_MANIFEST=$STATE_DIR/games.tsv
COVER_DIR=$BASE/covers
COVER_FETCHER=$MENU_DIR/fetch-covers
VOLUME_STATE=$STATE_DIR/menu-volume.state
LEGACY_SOUND_STATE=$STATE_DIR/menu-sound.state
KEYMAP_STATE=$STATE_DIR/terminal-keymap.state
TERMINAL=$BASE/terminal/retro-terminal
WIFI_HELPER=/usr/sbin/deck-wifi-profile-add
COMPILER=$MENU_DIR/compile-catalog.lisp
ECL=$BASE/ecl/bin/ecl.bin
ECLDIR=$BASE/ecl/lib/ecl/
LOG_FILE=$LOG_DIR/deck-menu.log
VOLUME_ON=42

export PATH LC_ALL ECLDIR TMPDIR
export INFONES_VOLUME_PERCENT=$VOLUME_ON
export RETRO_DECK_VOLUME_PERCENT=$VOLUME_ON

umask 077

if ! mkdir -p "$STATE_DIR" "$LOG_DIR" "$TMP_DIR"; then
	logger -t nes-deck-menu "cannot create persistent state directories under $BASE"
	exit 1
fi
chmod 0700 "$STATE_DIR" "$LOG_DIR" "$TMP_DIR" 2>/dev/null || :

rotate_log() {
	log_size=0
	if [ -f "$LOG_FILE" ]; then
		log_size=$(wc -c < "$LOG_FILE" 2>/dev/null) || log_size=0
		case $log_size in
			''|*[!0-9]*) log_size=0 ;;
		esac
	fi
	if [ "$log_size" -gt 262144 ]; then
		mv -f "$LOG_FILE" "$LOG_FILE.1" 2>/dev/null || :
	fi
}

log_message() {
	message=$1
	timestamp=$(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null) || timestamp=unknown-time
	printf '%s %s\n' "$timestamp" "$message" >> "$LOG_FILE" 2>/dev/null || :
	logger -t nes-deck-menu "$message" 2>/dev/null || :
}

write_state() {
	state_path=$1
	state_value=$2
	temporary_state=$state_path.tmp.$$
	if printf '%s\n' "$state_value" > "$temporary_state" &&
		mv -f "$temporary_state" "$state_path"; then
		return 0
	fi
	rm -f "$temporary_state"
	return 1
}

rotate_log

# Linux console blanking remains active even while a framebuffer process owns
# the visible pixels. Disable its ten-minute timer and wake scanout on every
# supervised launcher start, including boot and crash recovery.
if ! printf '\033[13]\033[9;0]' > /dev/tty0 2>/dev/null; then
	log_message "warning: cannot disable Linux console blanking on /dev/tty0"
fi
if [ -w /sys/class/graphics/fb0/blank ] &&
	! printf '0\n' > /sys/class/graphics/fb0/blank 2>/dev/null; then
	log_message "warning: cannot unblank fb0 through sysfs"
fi

if [ ! -x "$MENU" ]; then
	log_message "menu is missing or not executable: $MENU"
	exit 1
fi
if [ ! -x "$NES_EMULATOR" ]; then
	log_message "NES emulator is missing or not executable: $NES_EMULATOR"
	exit 1
fi
if [ ! -x "$GB_EMULATOR" ]; then
	log_message "GB/GBC emulator is missing or not executable: $GB_EMULATOR"
	exit 1
fi
if [ ! -x "$CHIP8_EMULATOR" ]; then
	log_message "CHIP-8 emulator is missing or not executable: $CHIP8_EMULATOR"
	exit 1
fi
if [ ! -x "$DECK_GAME" ]; then
	log_message "Deck game is missing or not executable: $DECK_GAME"
	exit 1
fi
if [ ! -x "$TERMINAL" ]; then
	log_message "terminal launcher is missing or not executable: $TERMINAL"
	exit 1
fi
if [ ! -x "$WIFI_HELPER" ]; then
	log_message "wifi profile helper is missing or not executable: $WIFI_HELPER"
	exit 1
fi
if [ ! -r "$FALLBACK_MANIFEST" ] || [ ! -s "$FALLBACK_MANIFEST" ]; then
	log_message "checked-in fallback manifest is missing or empty: $FALLBACK_MANIFEST"
	exit 1
fi

volume_value=
volume_size=0
if [ -r "$VOLUME_STATE" ]; then
	IFS= read -r volume_value < "$VOLUME_STATE" || volume_value=
	volume_size=$(wc -c < "$VOLUME_STATE" 2>/dev/null) || volume_size=0
	case $volume_size in
		''|*[!0-9]*) volume_size=0 ;;
	esac
fi
volume_valid=false
case $volume_value in
	0|[1-9]|[1-9][0-9]|100)
		expected_size=$((${#volume_value} + 1))
		if [ "$volume_size" -eq "$expected_size" ]; then
			volume_valid=true
		fi
		;;
esac
if [ "$volume_valid" != true ]; then
	initial_volume=$VOLUME_ON
	legacy_value=
	legacy_size=0
	if [ -r "$LEGACY_SOUND_STATE" ]; then
		IFS= read -r legacy_value < "$LEGACY_SOUND_STATE" || legacy_value=
		legacy_size=$(wc -c < "$LEGACY_SOUND_STATE" 2>/dev/null) || legacy_size=0
	fi
	case $legacy_value:$legacy_size in
		off:4) initial_volume=0 ;;
		on:3) initial_volume=$VOLUME_ON ;;
	esac
	if ! write_state "$VOLUME_STATE" "$initial_volume"; then
		log_message "cannot initialize volume state: $VOLUME_STATE"
		exit 1
	fi
	log_message "initialized game volume to ${initial_volume}%"
fi

keymap_value=
keymap_size=0
if [ -r "$KEYMAP_STATE" ]; then
	IFS= read -r keymap_value < "$KEYMAP_STATE" || keymap_value=
	keymap_size=$(wc -c < "$KEYMAP_STATE" 2>/dev/null) || keymap_size=0
fi
case $keymap_value:$keymap_size in
	us:3|cz:3) ;;
	*)
		if ! write_state "$KEYMAP_STATE" us; then
			log_message "cannot initialize terminal keymap state: $KEYMAP_STATE"
			exit 1
		fi
		log_message "initialized terminal keymap to US ANSI"
		;;
esac

manifest=$FALLBACK_MANIFEST
if [ -x "$ECL" ] && [ -r "$COMPILER" ] && [ -r "$CATALOG" ]; then
	log_message "validating menu catalog with ECL"
	if "$ECL" --norc --shell "$COMPILER" "$CATALOG" "$GENERATED_MANIFEST" \
		>> "$LOG_FILE" 2>&1 &&
		[ -r "$GENERATED_MANIFEST" ] && [ -s "$GENERATED_MANIFEST" ]; then
		manifest=$GENERATED_MANIFEST
		log_message "using generated manifest: $manifest"
	else
		log_message "catalog generation failed; using checked-in manifest: $FALLBACK_MANIFEST"
	fi
else
	log_message "ECL catalog compiler unavailable; using checked-in manifest: $FALLBACK_MANIFEST"
fi

if [ -x "$COVER_FETCHER" ]; then
	log_message "checking persistent Libretro cover cache"
	if ! "$COVER_FETCHER" "$manifest" "$COVER_DIR" >> "$LOG_FILE" 2>&1; then
		log_message "cover cache update failed; continuing with local covers"
	fi
fi

log_message "starting deck-menu with volume state $VOLUME_STATE and keymap state $KEYMAP_STATE"
exec "$MENU" \
	--nes-emulator "$NES_EMULATOR" \
	--gb-emulator "$GB_EMULATOR" \
	--chip8-emulator "$CHIP8_EMULATOR" \
	--deck-game "$DECK_GAME" \
	--volume-state "$VOLUME_STATE" \
	--keymap-state "$KEYMAP_STATE" \
	--terminal "$TERMINAL" \
	--wifi-helper "$WIFI_HELPER" \
	--manifest "$manifest" \
	--cover-directory "$COVER_DIR" \
	>> "$LOG_FILE" 2>&1
