#!/bin/sh

set -u

BASE=${RETRO_DECK_TERMINAL_BASE:-/mnt/data/nes-deck/terminal}
TTY=${RETRO_DECK_TERMINAL_TTY:-/dev/tty1}
LANG_BASE=${RETRO_DECK_LANG_BASE:-/mnt/data/langs}
LUA=${RETRO_DECK_LUA:-/mnt/data/nes-deck/langs/lua}
LISP=${RETRO_DECK_LISP:-/mnt/data/nes-deck/ecl/bin/ecl.bin}
ECLDIR=${RETRO_DECK_ECL_DIR:-/mnt/data/nes-deck/ecl/lib/ecl/}
PYTHON=${RETRO_DECK_PYTHON:-/mnt/data/nes-deck/langs/python}
SCHEME=${RETRO_DECK_SCHEME:-/mnt/data/nes-deck/langs/chibi/chibi-scheme}
CHIBI_MODULE_PATH=${RETRO_DECK_CHIBI_MODULE_PATH:-/mnt/data/nes-deck/langs/chibi/lib}
FBTERM=$BASE/fbterm
LOADKEYS=$BASE/loadkeys
KEYMAP_DIR=$BASE/keymaps
US_KEYMAP=$KEYMAP_DIR/us.map
CZ_KEYMAP=$KEYMAP_DIR/cz.map
FONTCONFIG_FILE=fonts.conf
FONTCONFIG_PATH=$BASE
HOME=/root
TERM=fbterm
SHELL=/bin/ash
PATH=/usr/sbin:/usr/bin:/sbin:/bin

export FONTCONFIG_FILE FONTCONFIG_PATH HOME TERM SHELL PATH CHIBI_MODULE_PATH
unset FONTCONFIG_SYSROOT

umask 077

fail() {
  printf 'retro-terminal: %s\n' "$1" >&2
  exit 1
}

[ -x "$FBTERM" ] || fail "fbterm is missing or not executable: $FBTERM"
[ -x "$LOADKEYS" ] || fail "loadkeys is missing or not executable: $LOADKEYS"
[ -c "$TTY" ] || fail "active console is unavailable: $TTY"
[ -r "$FONTCONFIG_PATH/$FONTCONFIG_FILE" ] ||
  fail "fontconfig file is unreadable: $FONTCONFIG_PATH/$FONTCONFIG_FILE"
[ -r "$US_KEYMAP" ] || fail "US keymap is unreadable: $US_KEYMAP"
[ -r "$CZ_KEYMAP" ] || fail "Czech keymap is unreadable: $CZ_KEYMAP"

[ "$#" -le 1 ] || fail "usage: retro-terminal [shell|lua|lisp|python|scheme]"
mode=${1:-shell}
case $mode in
  shell)
    set -- /bin/ash -l
    ;;
  lua)
    [ -x "$LUA" ] || fail "Lua interpreter is missing or not executable: $LUA"
    workdir=$LANG_BASE/lua
    mkdir -p "$workdir" || fail "cannot create Lua working directory: $workdir"
    cd "$workdir" || fail "cannot enter Lua working directory: $workdir"
    set -- "$LUA"
    ;;
  lisp)
    [ -x "$LISP" ] || fail "Lisp interpreter is missing or not executable: $LISP"
    [ -d "$ECLDIR" ] || fail "ECL runtime directory is unavailable: $ECLDIR"
    workdir=$LANG_BASE/lisp
    mkdir -p "$workdir" || fail "cannot create Lisp working directory: $workdir"
    cd "$workdir" || fail "cannot enter Lisp working directory: $workdir"
    export ECLDIR
    set -- "$LISP" --norc
    ;;
  python)
    [ -x "$PYTHON" ] || fail "Python interpreter is missing or not executable: $PYTHON"
    workdir=$LANG_BASE/python
    mkdir -p "$workdir" || fail "cannot create Python working directory: $workdir"
    cd "$workdir" || fail "cannot enter Python working directory: $workdir"
    set -- "$PYTHON"
    ;;
  scheme)
    [ -x "$SCHEME" ] || fail "Scheme interpreter is missing or not executable: $SCHEME"
    [ -r "$CHIBI_MODULE_PATH/init-7.scm" ] ||
      fail "Chibi Scheme module library is unavailable: $CHIBI_MODULE_PATH"
    workdir=$LANG_BASE/scheme
    mkdir -p "$workdir" || fail "cannot create Scheme working directory: $workdir"
    cd "$workdir" || fail "cannot enter Scheme working directory: $workdir"
    set -- "$SCHEME"
    ;;
  *)
    fail "mode must be 'shell', 'lua', 'lisp', 'python', or 'scheme'"
    ;;
esac

keymap=${RETRO_DECK_KEYMAP:-us}
case $keymap in
  us) selected_keymap=$US_KEYMAP ;;
  cz) selected_keymap=$CZ_KEYMAP ;;
  *) fail "RETRO_DECK_KEYMAP must be 'us' or 'cz'" ;;
esac

# The menu daemon has no interactive stdio. fbterm needs the active virtual
# console for keyboard input and VT ioctls. Keep stderr on the inherited
# persistent launcher log so initialization failures remain diagnosable.
exec 0<>"$TTY" 1>&0

restore_console() {
  "$LOADKEYS" -C "$TTY" -q -u "$US_KEYMAP" ||
    printf 'retro-terminal: could not restore US keymap\n' >&2
  printf '\033[?25l\033[13]\033[9;0]' > "$TTY" ||
    printf 'retro-terminal: could not restore console display state\n' >&2
}

# fbterm and this launcher share a process group. When the menu sends TERM,
# fbterm exits directly and the launcher's exit trap restores the console.
trap restore_console 0
signal_status=0
trap 'signal_status=129' HUP
trap 'signal_status=130' INT
trap 'signal_status=143' TERM

"$LOADKEYS" -C "$TTY" -q -u "$selected_keymap" ||
  fail "cannot load selected $keymap keymap"

"$FBTERM" -n 'DejaVu Sans Mono' -s 16 -f 7 -b 0 -- "$@" \
  0<>"$TTY" 1>&0 &
terminal_pid=$!
terminal_status=0
while kill -0 "$terminal_pid" 2>/dev/null; do
  wait "$terminal_pid" || terminal_status=$?
done
if [ "$signal_status" -ne 0 ]; then
  exit "$signal_status"
fi
exit "$terminal_status"
