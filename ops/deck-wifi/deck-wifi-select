#!/bin/sh

# Select a known IWD profile only after the Deck has lost complete network
# health. Profile names and credentials are never written to stdout or syslog.

PATH=${DECK_WIFI_PATH:-/usr/sbin:/usr/bin:/sbin:/bin}

PROFILE_DIR=${DECK_WIFI_PROFILE_DIR:-/etc/deck-wifi/profiles}
BACKUP_DIR=${DECK_WIFI_BACKUP_DIR:-/etc/deck-wifi/backups}
WIRELESS_CONFIG=${DECK_WIFI_CONFIG:-/etc/config/wireless}
RUNTIME_CONFIG=${DECK_WIFI_RUNTIME_CONFIG:-/var/run/wpa_supplicant-wlan0.conf}
STATUS_FILE=${DECK_WIFI_STATUS_FILE:-/var/run/deck-wifi/status}
IFACE=${DECK_WIFI_INTERFACE:-wlan0}
LOCK_DIR=${DECK_WIFI_LOCK_DIR:-/tmp/deck-wifi-select.lock}
TAB=$(printf '\t')
SCAN_CONFIRMATIONS=${DECK_WIFI_SCAN_CONFIRMATIONS:-1}
SCAN_INTERVAL=${DECK_WIFI_SCAN_INTERVAL:-5}
SCAN_RETRIES=${DECK_WIFI_SCAN_RETRIES:-3}
SCAN_RETRY_INTERVAL=${DECK_WIFI_SCAN_RETRY_INTERVAL:-3}
SWITCH_TIMEOUT=${DECK_WIFI_SWITCH_TIMEOUT:-60}
ROLLBACK_GRACE=${DECK_WIFI_ROLLBACK_GRACE:-20}
HEALTH_INTERVAL=${DECK_WIFI_HEALTH_INTERVAL:-2}

write_status() {
	status=$1
	status_directory=${STATUS_FILE%/*}
	[ "$status_directory" != "$STATUS_FILE" ] || return 1
	mkdir -p "$status_directory" 2>/dev/null || return 1
	chmod 0700 "$status_directory" 2>/dev/null || true
	current=
	if [ -r "$STATUS_FILE" ]; then
		IFS= read -r current < "$STATUS_FILE" || current=
	fi
	[ "$current" = "$status" ] && return 0
	temporary_status=$STATUS_FILE.tmp.$$
	if printf '%s\n' "$status" > "$temporary_status" &&
		chmod 0600 "$temporary_status" &&
		mv "$temporary_status" "$STATUS_FILE"; then
		logger -t deck-wifi "state: $status"
		return 0
	fi
	rm -f "$temporary_status" 2>/dev/null || true
	return 1
}

secure_files() {
	deck_wifi_root=${PROFILE_DIR%/*}
	chmod 0700 "$deck_wifi_root" "$PROFILE_DIR" "$BACKUP_DIR" 2>/dev/null || true
	chmod 0600 "$WIRELESS_CONFIG" "$RUNTIME_CONFIG" "$STATUS_FILE" 2>/dev/null || true
	for profile in "$PROFILE_DIR"/*.psk; do
		[ -f "$profile" ] || continue
		chmod 0600 "$profile" 2>/dev/null || true
	done
}

is_associated() {
	iw dev "$IFACE" link 2>/dev/null | grep -q '^Connected to '
}

has_ipv4() {
	ip -4 address show dev "$IFACE" 2>/dev/null |
		awk '$1 == "inet" { found=1 } END { exit !found }'
}

has_default_route() {
	ip -4 route show default 2>/dev/null |
		awk -v iface="$IFACE" '
			{ for (i=1; i<=NF; i++) if ($i == "dev" && $(i+1) == iface) found=1 }
			END { exit !found }
		'
}

network_ready() {
	is_associated && has_ipv4 && has_default_route
}

wait_for_network() {
	timeout=$1
	elapsed=0
	while [ "$elapsed" -lt "$timeout" ]; do
		network_ready && return 0
		sleep "$HEALTH_INTERVAL"
		elapsed=$((elapsed + HEALTH_INTERVAL))
	done
	network_ready
}

find_sta_section() {
	STA_SECTION=
	index=0
	while uci -q get "wireless.@wifi-iface[$index]" >/dev/null 2>&1; do
		mode=$(uci -q get "wireless.@wifi-iface[$index].mode" 2>/dev/null)
		disabled=$(uci -q get "wireless.@wifi-iface[$index].disabled" 2>/dev/null)
		if [ "$mode" = sta ] && [ "${disabled:-0}" != 1 ]; then
			STA_SECTION="@wifi-iface[$index]"
			return 0
		fi
		index=$((index + 1))
	done
	return 1
}

profile_hex() {
	profile_name=${1##*/}
	profile_name=${profile_name%.psk}
	case "$profile_name" in
		=*) printf '%s\n' "${profile_name#=}" | tr 'A-F' 'a-f' ;;
		*) printf '%s' "$profile_name" | xxd -p | tr -d '\n'; printf '\n' ;;
	esac
}

profile_enabled() {
	[ "$(awk -F= '$1 == "AutoConnect" { value=$2 } END { print value }' "$1")" != false ]
}

find_enabled_profile() {
	wanted_hex=$1
	SELECTED_PROFILE=
	for profile in "$PROFILE_DIR"/*.psk; do
		[ -f "$profile" ] || continue
		profile_enabled "$profile" || continue
		[ "$(profile_hex "$profile")" = "$wanted_hex" ] || continue
		SELECTED_PROFILE=$profile
		return 0
	done
	return 1
}

load_profile_key() {
	profile=$1
	SELECTED_KEY=$(awk -F= '
		$1 == "Passphrase" { sub(/^[^=]*=/, ""); print; found=1; exit }
		END { if (!found) exit 1 }
	' "$profile" 2>/dev/null) || SELECTED_KEY=
	if [ -n "$SELECTED_KEY" ]; then
		key_length=${#SELECTED_KEY}
		[ "$key_length" -ge 8 ] && [ "$key_length" -le 63 ] || return 1
		return 0
	fi
	SELECTED_KEY=$(awk -F= '
		$1 == "PreSharedKey" { sub(/^[^=]*=/, ""); print; found=1; exit }
		END { if (!found) exit 1 }
	' "$profile" 2>/dev/null) || SELECTED_KEY=
	[ "${#SELECTED_KEY}" -eq 64 ] || return 1
	case "$SELECTED_KEY" in
		*[!0-9A-Fa-f]*) return 1 ;;
	esac
	return 0
}

profile_ssid() {
	profile_name=${1##*/}
	profile_name=${profile_name%.psk}
	case "$profile_name" in
		=*) printf '%s' "${profile_name#=}" | xxd -r -p ;;
		*) printf '%s' "$profile_name" ;;
	esac
}

cleanup() {
	rm -f "${SCAN_IW:-}" "${SCAN_RAW:-}" "${SCAN_HEX:-}" \
		"${SCAN_SORTED:-}" "${CANDIDATES:-}" "${CURRENT_CANDIDATE:-}" \
		2>/dev/null || true
	[ -n "${UCI_WORK:-}" ] && rm -rf "$UCI_WORK" 2>/dev/null || true
	[ -n "${RESTORE_WORK:-}" ] && rm -f "$RESTORE_WORK" 2>/dev/null || true
	rmdir "$LOCK_DIR" 2>/dev/null || true
}

parse_iwinfo_scan() {
	awk '
		function emit() {
			if (length(ssid) > 0) printf "%s\t%d\t%s\n", signal, psk, ssid
		}
		/^Cell / {
			emit()
			signal=-1000
			ssid=""
			psk=0
			next
		}
		/^[[:space:]]*Signal:/ { signal=$2; next }
		/^[[:space:]]*Encryption:/ {
			if (index($0, "PSK")) psk=1
			next
		}
		/^[[:space:]]*ESSID: "/ {
			ssid=$0
			sub(/^[[:space:]]*ESSID: "/, "", ssid)
			sub(/"$/, "", ssid)
			next
		}
		END { emit() }
	' "$SCAN_IW" > "$SCAN_RAW"
}

parse_iw_scan() {
	awk '
		function emit() {
			if (length(ssid) > 0) printf "%s\t%d\t%s\n", signal, psk, ssid
		}
		/^BSS / {
			emit()
			signal=-1000
			ssid=""
			psk=0
			next
		}
		/^[[:space:]]*signal:/ { signal=$2; next }
		/Authentication suites:/ {
			if (index($0, "PSK")) psk=1
			next
		}
		/^[[:space:]]*SSID:/ {
			ssid=$0
			sub(/^[[:space:]]*SSID: /, "", ssid)
			next
		}
		END { emit() }
	' "$SCAN_IW" > "$SCAN_RAW"
}

scan_once() {
	: > "$SCAN_IW"
	: > "$SCAN_RAW"
	: > "$SCAN_HEX"
	: > "$SCAN_SORTED"

	if command -v iwinfo >/dev/null 2>&1 &&
		iwinfo "$IFACE" scan > "$SCAN_IW" 2>/dev/null; then
		parse_iwinfo_scan
	fi
	if [ ! -s "$SCAN_RAW" ]; then
		: > "$SCAN_IW"
		if ! iw dev "$IFACE" scan > "$SCAN_IW" 2>/dev/null; then
			return 1
		fi
		parse_iw_scan
	fi
	[ -s "$SCAN_RAW" ] || return 1

	while IFS="$TAB" read -r signal advertises_psk ssid; do
		ssid_hex=$(printf '%s' "$ssid" | xxd -p | tr -d '\n' | tr 'A-F' 'a-f')
		[ -n "$ssid_hex" ] || continue
		printf '%s\t%s\t%s\n' "$signal" "$advertises_psk" "$ssid_hex"
	done < "$SCAN_RAW" > "$SCAN_HEX"
	sort -rn -k1,1 "$SCAN_HEX" > "$SCAN_SORTED"
	[ -s "$SCAN_SORTED" ]
}

build_candidate_list() {
	: > "$CANDIDATES"
	: > "$CURRENT_CANDIDATE"
	while IFS="$TAB" read -r _signal advertises_psk candidate_hex; do
		[ "$advertises_psk" = 1 ] || continue
		find_enabled_profile "$candidate_hex" || continue
		load_profile_key "$SELECTED_PROFILE" || continue
		if grep -F -q "$candidate_hex$TAB" "$CANDIDATES" "$CURRENT_CANDIDATE" \
			2>/dev/null; then
			continue
		fi
		if [ -n "$current_hex" ] && [ "$candidate_hex" = "$current_hex" ]; then
			printf '%s\t%s\n' "$candidate_hex" "$SELECTED_PROFILE" \
				>> "$CURRENT_CANDIDATE"
		else
			printf '%s\t%s\n' "$candidate_hex" "$SELECTED_PROFILE" \
				>> "$CANDIDATES"
		fi
	done < "$SCAN_SORTED"
	cat "$CURRENT_CANDIDATE" >> "$CANDIDATES"
}

apply_profile() {
	profile=$1
	selected_ssid=$(profile_ssid "$profile")
	load_profile_key "$profile" || return 1
	[ -n "$selected_ssid" ] || return 1

	UCI_WORK=$BACKUP_DIR/.uci.$$
	rm -rf "$UCI_WORK" 2>/dev/null || true
	mkdir "$UCI_WORK" || return 1
	chmod 0700 "$UCI_WORK" || return 1
	cp "$backup" "$UCI_WORK/wireless" || return 1
	chmod 0600 "$UCI_WORK/wireless" || return 1
	uci -c "$UCI_WORK" -q set "wireless.${STA_SECTION}.ssid=$selected_ssid" || return 1
	uci -c "$UCI_WORK" -q set "wireless.${STA_SECTION}.key=$SELECTED_KEY" || return 1
	uci -c "$UCI_WORK" -q set "wireless.${STA_SECTION}.encryption=psk2" || return 1
	uci -c "$UCI_WORK" -q set "wireless.${STA_SECTION}.disabled=0" || return 1
	uci -c "$UCI_WORK" -q commit wireless || return 1
	chmod 0600 "$UCI_WORK/wireless"
	mv "$UCI_WORK/wireless" "$WIRELESS_CONFIG" || return 1
	rmdir "$UCI_WORK"
	UCI_WORK=
	chmod 0600 "$WIRELESS_CONFIG"
	wifi reload >/dev/null 2>&1 || true
	sleep 2
	secure_files
}

restore_wireless_config() {
	RESTORE_WORK=$BACKUP_DIR/.wireless-restore.$$
	cp "$backup" "$RESTORE_WORK" || return 1
	chmod 0600 "$RESTORE_WORK" || return 1
	mv "$RESTORE_WORK" "$WIRELESS_CONFIG" || return 1
	RESTORE_WORK=
	chmod 0600 "$WIRELESS_CONFIG"
	wifi reload >/dev/null 2>&1 || true
	sleep 2
	secure_files
}

umask 077
mkdir "$LOCK_DIR" 2>/dev/null || exit 0
trap cleanup EXIT INT TERM

secure_files
case "${1:-}" in
	--secure-only) exit 0 ;;
	--health-check) network_ready ; exit $? ;;
	"") ;;
	*) exit 2 ;;
esac

if network_ready; then
	write_status "CONNECTED" || true
	exit 0
fi
[ -d "$PROFILE_DIR" ] || {
	write_status "NO SAVED WIFI PROFILES" || true
	exit 1
}
find_sta_section || {
	write_status "NO ENABLED WIFI STATION" || true
	exit 1
}

SCAN_IW=${DECK_WIFI_TMP_DIR:-/tmp}/deck-wifi-scan-iw.$$
SCAN_RAW=${DECK_WIFI_TMP_DIR:-/tmp}/deck-wifi-scan-raw.$$
SCAN_HEX=${DECK_WIFI_TMP_DIR:-/tmp}/deck-wifi-scan-hex.$$
SCAN_SORTED=${DECK_WIFI_TMP_DIR:-/tmp}/deck-wifi-scan-sorted.$$
CANDIDATES=${DECK_WIFI_TMP_DIR:-/tmp}/deck-wifi-candidates.$$
CURRENT_CANDIDATE=${DECK_WIFI_TMP_DIR:-/tmp}/deck-wifi-current.$$

current_ssid=$(uci -q get "wireless.${STA_SECTION}.ssid" 2>/dev/null)
if [ -n "$current_ssid" ]; then
	current_hex=$(printf '%s' "$current_ssid" | xxd -p | tr -d '\n' | tr 'A-F' 'a-f')
else
	current_hex=
fi

write_status "SCANNING KNOWN WIFI" || true
confirmation=0
while [ "$confirmation" -lt "$SCAN_CONFIRMATIONS" ]; do
	if network_ready; then
		write_status "CONNECTED" || true
		exit 0
	fi
	retry=0
	scan_succeeded=false
	while [ "$retry" -lt "$SCAN_RETRIES" ]; do
		if scan_once; then
			scan_succeeded=true
			break
		fi
		retry=$((retry + 1))
		[ "$retry" -ge "$SCAN_RETRIES" ] && break
		write_status "WIFI SCAN RETRY $retry OF $SCAN_RETRIES" || true
		sleep "$SCAN_RETRY_INTERVAL"
		if network_ready; then
			write_status "CONNECTED" || true
			exit 0
		fi
	done
	if [ "$scan_succeeded" != true ]; then
		write_status "WIFI SCAN FAILED" || true
		exit 1
	fi
	confirmation=$((confirmation + 1))
	[ "$confirmation" -ge "$SCAN_CONFIRMATIONS" ] || sleep "$SCAN_INTERVAL"
done

build_candidate_list
candidate_count=$(wc -l < "$CANDIDATES" 2>/dev/null) || candidate_count=0
case "$candidate_count" in
	''|*[!0-9]*) candidate_count=0 ;;
esac
if [ "$candidate_count" -eq 0 ]; then
	write_status "NO VISIBLE KNOWN WIFI" || true
	exit 1
fi

if network_ready; then
	write_status "CONNECTED" || true
	exit 0
fi

mkdir -p "$BACKUP_DIR"
chmod 0700 "$BACKUP_DIR"
stamp=$(date +%Y%m%d-%H%M%S)
backup=$BACKUP_DIR/wireless.${stamp}.$$.before-switch
cp -p "$WIRELESS_CONFIG" "$backup" || {
	write_status "WIFI BACKUP FAILED" || true
	exit 1
}
chmod 0600 "$backup"

attempt=0
while IFS="$TAB" read -r _candidate_hex candidate_profile; do
	attempt=$((attempt + 1))
	if network_ready; then
		write_status "CONNECTED" || true
		exit 0
	fi
	write_status "TRYING KNOWN WIFI $attempt OF $candidate_count" || true
	logger -t deck-wifi "trying visible known PSK profile $attempt of $candidate_count"
	if ! apply_profile "$candidate_profile"; then
		logger -t deck-wifi "could not apply known PSK profile $attempt"
		continue
	fi
	if wait_for_network "$SWITCH_TIMEOUT"; then
		write_status "CONNECTED" || true
		logger -t deck-wifi "known PSK profile $attempt reached complete network health"
		exit 0
	fi
	logger -t deck-wifi "known PSK profile $attempt failed its bounded health check"
done < "$CANDIDATES"

write_status "RESTORING PREVIOUS WIFI" || true
logger -t deck-wifi 'all visible known PSK profiles failed; restoring previous wireless config'
if ! restore_wireless_config; then
	write_status "WIFI RESTORE FAILED" || true
	logger -t deck-wifi 'failed to restore previous wireless config'
	exit 1
fi
if wait_for_network "$ROLLBACK_GRACE"; then
	write_status "CONNECTED" || true
	logger -t deck-wifi 'previous wireless config recovered complete network health'
	exit 0
fi

write_status "NO KNOWN WIFI CONNECTED" || true
logger -t deck-wifi 'no known Wi-Fi reached complete network health'
exit 1
