+/*
+ * g_wPassedClocks is only the CPU core's carry within the current
+ * scanline.  The old code treated it as a frame clock, so every APU write
+ * received a small negative timestamp and all register changes were applied
+ * to sample zero of the next 735-sample block.  Build a monotonic offset from
+ * the current scanline instead.  An audio frame begins at VBLANK_START.
+ */
+static long ApuFrameCycles(void)
+{
+  unsigned int lines;
+  if ( PPU_Scanline >= SCAN_VBLANK_START )
+    lines = PPU_Scanline - SCAN_VBLANK_START;
+  else
+    lines = ( SCAN_VBLANK_END - SCAN_VBLANK_START + 1 ) + PPU_Scanline;
+  return (long)lines * STEP_PER_SCANLINE + g_wPassedClocks;
+}
+
 #define APU_WRITEFUNC(name, evtype) \
 void ApuWrite##name(WORD addr, BYTE value) \
 { \
-  ApuEventQueue[cur_event].time = entertime - g_wPassedClocks; \
+  if ( cur_event >= APU_EVENT_MAX ) return; \
+  ApuEventQueue[cur_event].time = ApuFrameCycles(); \
   ApuEventQueue[cur_event].type = APUET_W_##evtype; \
   ApuEventQueue[cur_event].data = value; \
   cur_event++; \
