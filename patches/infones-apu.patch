-void InfoNES_pAPUVsync(void)
-{
-  ApuRenderingWave1();
+void InfoNES_pAPUVsync(void)
+{
+  /* Length counters and envelopes are clocked per video frame, not per
+   * generated PCM sample.  The old Linux fork did this work inside each
+   * 735-sample render loop, while also storing phases in unsigned DWORDs;
+   * that made the "phase < 0" tests unreachable and collapsed triangle
+   * counters in a fraction of one frame. */
+  if ( ApuC1Atl && !ApuC1Hold )
+    ApuC1Atl--;
+  ApuC1EnvPhase -= 4;
+  while ( ApuC1EnvPhase < 0 )
+  {
+    ApuC1EnvPhase += ApuC1EnvDelay;
+    if ( ApuC1Hold )
+      ApuC1EnvVol = ( ApuC1EnvVol - 1 ) & 0x0f;
+    else if ( ApuC1EnvVol > 0 )
+      ApuC1EnvVol--;
+  }
+  if ( ApuC1SweepOn && ApuC1SweepShifts && ApuC1Freq >= 8 )
+  {
+    ApuC1SweepPhase -= 2;
+    while ( ApuC1SweepPhase < 0 )
+    {
+      ApuC1SweepPhase += ApuC1SweepDelay;
+      if ( ApuC1SweepIncDec )
+        ApuC1Freq += ~( ApuC1Freq >> ApuC1SweepShifts );
+      else
+        ApuC1Freq += ApuC1Freq >> ApuC1SweepShifts;
+    }
+    if ( ApuC1Freq >= 2 )
+      ApuC1Skip = ApuPulseMagic / ( ApuC1Freq / 2 );
+  }
+
+  if ( ApuC2Atl && !ApuC2Hold )
+    ApuC2Atl--;
+  ApuC2EnvPhase -= 4;
+  while ( ApuC2EnvPhase < 0 )
+  {
+    ApuC2EnvPhase += ApuC2EnvDelay;
+    if ( ApuC2Hold )
+      ApuC2EnvVol = ( ApuC2EnvVol - 1 ) & 0x0f;
+    else if ( ApuC2EnvVol > 0 )
+      ApuC2EnvVol--;
+  }
+  if ( ApuC2SweepOn && ApuC2SweepShifts && ApuC2Freq >= 8 )
+  {
+    ApuC2SweepPhase -= 2;
+    while ( ApuC2SweepPhase < 0 )
+    {
+      ApuC2SweepPhase += ApuC2SweepDelay;
+      if ( ApuC2SweepIncDec )
+        ApuC2Freq -= ApuC2Freq >> ApuC2SweepShifts;
+      else
+        ApuC2Freq += ApuC2Freq >> ApuC2SweepShifts;
+    }
+    if ( ApuC2Freq >= 2 )
+      ApuC2Skip = ApuPulseMagic / ( ApuC2Freq / 2 );
+  }
+
+  if ( ApuC3Holdnote )
+    ApuC3Llc = ApuC3LinearLength;
+  else if ( ApuC3Llc > 4 * 64 )
+    ApuC3Llc -= 4 * 64;
+  else
+    ApuC3Llc = 0;
+  if ( ApuC3Atl && !ApuC3Holdnote )
+    ApuC3Atl--;
+
+  if ( ApuC4Atl && !ApuC4Hold )
+    ApuC4Atl--;
+  ApuC4EnvPhase -= 4;
+  while ( ApuC4EnvPhase < 0 )
+  {
+    ApuC4EnvPhase += ApuC4EnvDelay;
+    if ( ApuC4Hold )
+      ApuC4EnvVol = ( ApuC4EnvVol - 1 ) & 0x0f;
+    else if ( ApuC4EnvVol > 0 )
+      ApuC4EnvVol--;
+  }
+
+  ApuRenderingWave1();
   ApuRenderingWave2();
   ApuRenderingWave3();
   ApuRenderingWave4();
