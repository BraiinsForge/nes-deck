<?xml version="1.0" encoding="UTF-8"?>
<protocol name="deck_widget_v1">
  <copyright>
    Copyright (C) 2025 Braiins Systems s.r.o.
    SPDX-License-Identifier: MIT

    This compact client copy preserves the wire interface from bmc-main.
  </copyright>

  <interface name="deck_widget_manager_v1" version="1">
    <request name="destroy" type="destructor"/>
    <request name="get_widget_surface">
      <arg name="id" type="new_id" interface="deck_widget_surface_v1"/>
      <arg name="surface" type="object" interface="wl_surface"/>
    </request>
  </interface>

  <interface name="deck_widget_surface_v1" version="1">
    <request name="destroy" type="destructor"/>
    <request name="play_sound">
      <arg name="sound" type="string"/>
    </request>
    <request name="stop_sound"/>
    <request name="led_temporary">
      <arg name="request_id" type="uint"/>
      <arg name="effect" type="uint"/>
      <arg name="r" type="uint"/>
      <arg name="g" type="uint"/>
      <arg name="b" type="uint"/>
      <arg name="period_ms" type="uint"/>
      <arg name="duration_ms" type="uint"/>
      <arg name="scope" type="uint"/>
    </request>
    <request name="led_endless">
      <arg name="request_id" type="uint"/>
      <arg name="effect" type="uint"/>
      <arg name="r" type="uint"/>
      <arg name="g" type="uint"/>
      <arg name="b" type="uint"/>
      <arg name="period_ms" type="uint"/>
      <arg name="scope" type="uint"/>
    </request>
    <request name="stop_led">
      <arg name="request_id" type="uint"/>
    </request>

    <event name="configure">
      <arg name="width" type="uint"/>
      <arg name="height" type="uint"/>
      <arg name="viewport_shape" type="uint"/>
      <arg name="token" type="string"/>
    </event>
    <event name="display_info">
      <arg name="width" type="uint"/>
      <arg name="height" type="uint"/>
      <arg name="shape" type="uint"/>
      <arg name="dpi" type="uint"/>
    </event>
    <event name="params">
      <arg name="json" type="string"/>
    </event>
    <event name="configure_done"/>
    <event name="timezone">
      <arg name="value" type="string"/>
    </event>
    <event name="night_mode"><arg name="value" type="uint"/></event>
    <event name="date_format"><arg name="value" type="uint"/></event>
    <event name="time_format"><arg name="value" type="uint"/></event>
    <event name="number_format"><arg name="value" type="uint"/></event>
    <event name="temperature_unit"><arg name="value" type="uint"/></event>
    <event name="first_day_of_week"><arg name="value" type="uint"/></event>
    <event name="unit_system"><arg name="value" type="uint"/></event>
    <event name="next_alarm">
      <arg name="present" type="uint"/>
      <arg name="fire_at_utc_ms_hi" type="int"/>
      <arg name="fire_at_utc_ms_lo" type="uint"/>
      <arg name="name" type="string"/>
    </event>
    <event name="lifecycle"><arg name="state" type="uint"/></event>
    <event name="shutdown"/>
    <event name="transition_incoming"/>
    <event name="led_request_status">
      <arg name="request_id" type="uint"/>
      <arg name="status" type="uint"/>
    </event>
  </interface>
</protocol>
