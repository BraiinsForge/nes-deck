(load "@startup@" :verbose nil :print nil)

(in-package #:retrodeck)

(defun main ()
  (unless (= (retrodeck.native:abi-version) 12)
    (error "Native ABI mismatch"))
  (unless (= (retrodeck.native:canvas-clear #x121212) 1)
    (error "Canvas clear callback did not accept one argument"))
  (unless (= (retrodeck.native:canvas-draw-glyph -4 8 65 2 #xfe6c27) 1)
    (error "Canvas glyph callback did not accept five arguments"))
  (unless (= (retrodeck.native:canvas-draw-glyph 0 0 255 1 0) 1)
    (error "Canvas glyph callback rejected byte 255"))
  (unless (zerop (retrodeck.native:canvas-draw-glyph 0 0 256 1 0))
    (error "Canvas glyph callback accepted a non-byte character"))
  (unless (zerop (retrodeck.native:canvas-draw-glyph 0 0 65 0 0))
    (error "Canvas glyph callback accepted a zero scale"))
  (unless (= (retrodeck.native:canvas-fill-rect -4 8 12 16 #xfe6c27) 1)
    (error "Canvas rectangle callback did not accept five arguments"))
  (unless (handler-case
              (progn (fill-canvas-rect #x80000000 0 1 1 0) nil)
            (type-error () t))
    (error "Canvas x coordinate exceeded the native signed range"))
  (unless (handler-case
              (progn (fill-canvas-rect 0 0 #x100000000 1 0) nil)
            (type-error () t))
    (error "Canvas width exceeded the native unsigned range"))
  (let ((credits (read-bounded-regular-file "@credits@" 1 32768)))
      (unless (and credits (search "FCEUmm" credits))
        (error "Bounded regular-file callback did not read credits")))
    (when (read-bounded-regular-file "/no/such/retrodeck-credits.tsv" 1 32768)
      (error "Missing regular file unexpectedly loaded"))
    (when (retrodeck.native:read-regular-file "@credits@" 1 4194305)
      (error "Regular-file callback accepted an oversized bound"))
    (let ((mask (load-text-mask "HHHHHHHHHH" 4)))
      (unless mask
        (error "Projected text mask callback did not load text"))
      (unless (configure-text-projection
               1000 1 20 4044 420 4000 56 72 104 210 480 #xffffaf)
        (error "Projected text callback rejected reference geometry"))
      (unless (draw-projected-text mask 0)
        (error "Projected text callback rejected its mask")))
    (unless (clear-text-mask-cache)
      (error "Projected text mask cache did not clear"))
    (unless (zerop (retrodeck.native:canvas-draw-projected-text 1 0))
      (error "Cleared projected text mask remained available"))
    (let* ((credits (load-project-credits "@credits@"))
           (crawl (make-project-credits-crawl credits)))
      (prepare-project-credits-crawl crawl)
      (dolist (fixture '((nil 0 #x94ebf079be6e596b)
                         (nil 2000 #x1f14f6b786549363)
                         (nil 20000 #x6267b51f6f787c83)
                         (nil 600000000 #xf62d9d0147c7461a)
                         (t 0 #x9a44bcef4a13dde3)
                         (t 60000 #x9a44bcef4a13dde3)))
        (destructuring-bind (reduced-motion elapsed-ms expected) fixture
          (unless (equal (render-project-credits
                          crawl reduced-motion elapsed-ms)
                         '(:close (1212 12 56 56)))
            (error "Credits layout crossed the native boundary incorrectly"))
          (unless (= (canvas-rgb565-hash) expected)
            (error "Credits frame mismatch at ~D ms" elapsed-ms))))
      (clear-credits-text-mask-cache))
    (let ((network '(:ssid "net1" :wlan-ipv4 "10.249.110.248"
                     :wireguard-ipv4 "10.0.0.10" :selector "CONNECTED")))
      (dolist (fixture
               '((42 60 "us" :volume-down "" #x46d1527abb9f2bcb)
                 (0 60 "us" :volume-up "" #xc2c55ee7eb47608b)
                 (42 100 "us" :brightness-up "" #x6e348df7ca27725f)
                 (42 60 "cz" :keymap "" #x99ed5871b55b5f6b)
                 (42 60 "us" :wifi "" #x65f7d573c69bccbb)
                 (42 60 "us" :terminal "" #x9cabcc3df5188ce3)
                 (42 60 "us" :volume-down
                  "VOLUME SAVED; CONFIRMATION TONE FAILED"
                  #x05a5652bb03e0b8b)
                 (42 60 "us" :volume-down
                  "THIS SETTINGS STATUS FIXTURE IS INTENTIONALLY LONG ENOUGH TO USE THE SMALL FOOTER SCALE ACROSS THE COMPLETE DISPLAY"
                  #x773a6a165672bd8b)))
        (destructuring-bind
            (volume brightness keymap selected status expected) fixture
          (unless (equal (render-dashboard-settings
                          volume brightness keymap selected status network)
                         '(:close (1212 12 56 56)
                           :wifi (926 20 262 108)
                           :volume-down (108 208 104 104)
                           :volume-up (228 208 104 104)
                           :brightness-down (438 208 104 104)
                           :brightness-up (558 208 104 104)
                           :terminal (792 208 112 104)
                           :keymap (1036 208 112 104)))
            (error "Settings layout crossed the native boundary incorrectly"))
          (unless (= (canvas-rgb565-hash) expected)
            (error "Settings frame mismatch for ~S" selected)))))
    (dolist (fixture
             '(("" "" :ssid nil nil 30 #\q #\- #xd6be2f43c4faf0e6)
               ("" "" :ssid t nil 30 #\Q #\- #x7682dc83b0062730)
               ("NETWORK" "password" :passphrase t nil
                30 #\Q #\- #xa5c18f4c41654088)
               ("NETWORK" "password" :passphrase nil t
                42 #\1 #\> #xf919741f85fe2c31)))
      (destructuring-bind
          (ssid passphrase field uppercase symbols
           key-count first-key last-key expected)
          fixture
        (let* ((network '(:ssid "net1" :wlan-ipv4 "10.249.110.248"
                          :wireguard-ipv4 "10.0.0.10"
                          :selector "CONNECTED"))
               (state (wifi-initial-state
                       :ssid ssid :passphrase passphrase :field field
                       :uppercase uppercase :symbols symbols))
               (layout (render-dashboard-wifi state network))
               (keys (getf layout :keys)))
          (unless (and
                   (equal (subseq layout 0 16)
                          '(:back (16 10 120 62)
                            :ssid (330 10 310 62)
                            :passphrase (650 10 330 62)
                            :save (990 10 274 62)
                            :mode (16 364 152 66)
                            :shift (176 364 168 66)
                            :space (352 364 700 66)
                            :delete (1060 364 204 66)))
                   (= (length keys) key-count)
                   (char= (second (first keys)) first-key)
                   (char= (second (car (last keys))) last-key))
            (error "Wi-Fi layout crossed the native boundary incorrectly"))
          (unless (= (canvas-rgb565-hash) expected)
            (error "Wi-Fi frame mismatch for ~S/~S"
                   field (if symbols :symbols
                             (if uppercase :uppercase :lowercase)))))))
    (let ((plan '(:executable "@terminal_fixture@"
                  :arguments ("shell")
                  :environment (("RETRO_DECK_KEYMAP" . "cz"))
                  :label "terminal"
                  :touch-supervision t
                  :mirror-console t)))
      (unless (string= (dashboard-terminal-starting-status plan)
                       "STARTING TERMINAL")
        (error "Terminal starting status changed"))
      (let ((result (run-dashboard-terminal plan)))
        (unless (equal result
                       '(:started t :exited-for-touch nil
                         :exit-code 0 :signal nil :error nil))
          (error "Terminal process callback result changed: ~S" result))
        (unless (string= (dashboard-terminal-result-status plan result)
                         "TERMINAL EXITED")
          (error "Terminal return status changed"))))
    (dolist (fixture '(("failure" :exit-code 7
                         "TERMINAL EXITED (STATUS 7)")
                       ("signal" :signal 15
                         "TERMINAL STOPPED (SIGNAL 15)")))
      (destructuring-bind (mode field expected-value expected-status) fixture
        (let* ((plan (list :executable "@terminal_fixture@"
                           :arguments (list mode)
                           :environment '(("RETRO_DECK_KEYMAP" . "cz"))
                           :label "terminal"
                           :touch-supervision t
                           :mirror-console t))
               (result (run-dashboard-terminal plan)))
          (unless (and (eql (getf result field) expected-value)
                       (string= (dashboard-terminal-result-status plan result)
                                expected-status))
            (error "Terminal ~A result changed: ~S" mode result)))))
    (let* ((plan '(:executable "/no/such/retrodeck-terminal"
                   :arguments ("shell")
                   :environment (("RETRO_DECK_KEYMAP" . "cz"))
                   :label "terminal"
                   :touch-supervision t
                   :mirror-console t))
           (result (run-dashboard-terminal plan)))
      (unless (and (not (getf result :started))
                   (stringp (getf result :error))
                   (string= (dashboard-terminal-result-status plan result)
                            "TERMINAL ERROR - CHECK LOG"))
        (error "Terminal exec failure result changed: ~S" result)))
    (let ((icon (load-png-raster "@settings_icon@" 23 23)))
      (unless icon
        (error "PNG raster callback did not load the settings asset"))
      (unless (draw-canvas-raster icon 3 5 50 50)
        (error "Canvas raster callback did not accept five arguments")))
    (let ((cover (load-cover-raster "@settings_icon@" #x5f87ff)))
      (unless cover
        (error "Cover raster callback did not load a PNG"))
      (unless (draw-canvas-raster cover 60 5 50 50)
        (error "Cover raster did not draw")))
    (unless (clear-dashboard-raster-cache)
      (error "Native raster cache did not clear"))
    (when (load-png-raster "/no/such/retrodeck-raster.png" 23 23)
      (error "Missing PNG raster unexpectedly loaded"))
    (retrodeck.native:evdev-controls-close)
    (unless (and (null (retrodeck.native:evdev-next-control))
                 (equal (retrodeck.native:evdev-controls-dispatch 0) '(0 0)))
      (error "Closed evdev controls crossed the native boundary incorrectly"))
    (let ((counts (retrodeck.native:evdev-controls-scan)))
      (when counts
        (unless (and (= (length counts) 2)
                     (<= 0 (first counts) 2)
                     (<= 0 (second counts) 4))
          (error "Evdev control scan crossed the native boundary incorrectly"))))
    (retrodeck.native:evdev-controls-close)
    (unless (and (equal (dashboard-control-actions
                         '(:kind :keyboard :code 15
                           :shift t :repeat nil))
                        '(:system-previous))
                 (equal (dashboard-control-actions
                         '(:kind :gamepad :edges #x244))
                        '(:confirm :system-next :right))
                 (eq (dashboard-controller-command
                      '(:system-next :confirm) nil nil)
                     :system-next)
                 (dashboard-controller-scan-due-p 0 999))
      (error "Controller policy failed under target ECL"))
    (multiple-value-bind (guard accepted suspended)
        (dashboard-controller-guard-accept-edge
         (dashboard-controller-guard-initial-state) 10)
      (unless (and accepted (not suspended)
                   (equal (getf guard :edge-times) '(10)))
        (error "Controller guard failed under target ECL")))
    (unless (and (null (retrodeck.native:evdev-next-touch))
                 (= (retrodeck.native:evdev-touch-dispatch 0) -1))
      (error "Closed evdev touch state crossed the native boundary incorrectly"))
    (retrodeck.native:evdev-touch-close)
    (unless (null (retrodeck.native:fbdev-size))
    (error "Closed fbdev state crossed the native boundary incorrectly"))
  (unless (zerop (retrodeck.native:fbdev-present-canvas))
    (error "Closed fbdev canvas presentation succeeded"))
  (unless (zerop (retrodeck.native:fbdev-present-solid 0))
    (error "fbdev solid callback did not accept one argument"))
  (retrodeck.native:fbdev-close)
  (unless (and (null (retrodeck.native:wayland-size))
               (null (retrodeck.native:wayland-next-touch))
               (zerop (retrodeck.native:wayland-shutdown-p)))
    (error "Closed Wayland state crossed the native boundary incorrectly"))
  (unless (zerop (retrodeck.native:wayland-present-canvas))
    (error "Closed Wayland canvas presentation succeeded"))
  (unless (zerop (retrodeck.native:wayland-present-solid 0))
    (error "Wayland solid callback did not accept one argument"))
  (unless (= (retrodeck.native:wayland-dispatch 0) -1)
    (error "Wayland dispatch callback did not accept one argument"))
  (retrodeck.native:wayland-close)
  (unless (= (retrodeck.native:play-tones 659 25 0 0 0) 0)
    (error "Invalid audio request crossed the native boundary"))
  (unless (play-menu-sound :confirm 42)
    (error "Native audio worker did not start"))
  (unless (menu-sound-blocks-input-p :controller)
    (error "Controller quarantine was not active"))
  (when (menu-sound-blocks-input-p :touch)
    (error "Menu sound blocked touch"))
  (stop-menu-sound)
  (unless (= (retrodeck.native:audio-active-p) 0)
    (error "Native audio worker did not stop"))
  (finish-menu-sound)
  0)
