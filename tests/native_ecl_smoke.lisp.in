(load "@startup@" :verbose nil :print nil)

(in-package #:retrodeck)

(defun main ()
  (unless (= (retrodeck.native:abi-version) 6)
    (error "Native ABI mismatch"))
  (unless (= (retrodeck.native:canvas-clear #x121212) 1)
    (error "Canvas clear callback did not accept one argument"))
  (unless (= (retrodeck.native:canvas-draw-glyph -4 8 65 2 #xfe6c27) 1)
    (error "Canvas glyph callback did not accept five arguments"))
  (unless (= (retrodeck.native:canvas-draw-glyph 0 0 255 1 0) 1)
    (error "Canvas glyph callback rejected byte 255"))
  (unless (zerop (retrodeck.native:canvas-draw-glyph 0 0 256 1 0))
    (error "Canvas glyph callback accepted a non-byte character"))
  (unless (zerop (retrodeck.native:canvas-draw-glyph 0 0 65 0 0))
    (error "Canvas glyph callback accepted a zero scale"))
  (unless (= (retrodeck.native:canvas-fill-rect -4 8 12 16 #xfe6c27) 1)
    (error "Canvas rectangle callback did not accept five arguments"))
  (unless (handler-case
              (progn (fill-canvas-rect #x80000000 0 1 1 0) nil)
            (type-error () t))
    (error "Canvas x coordinate exceeded the native signed range"))
  (unless (handler-case
              (progn (fill-canvas-rect 0 0 #x100000000 1 0) nil)
            (type-error () t))
    (error "Canvas width exceeded the native unsigned range"))
  (unless (null (retrodeck.native:fbdev-size))
    (error "Closed fbdev state crossed the native boundary incorrectly"))
  (unless (zerop (retrodeck.native:fbdev-present-canvas))
    (error "Closed fbdev canvas presentation succeeded"))
  (unless (zerop (retrodeck.native:fbdev-present-solid 0))
    (error "fbdev solid callback did not accept one argument"))
  (retrodeck.native:fbdev-close)
  (unless (and (null (retrodeck.native:wayland-size))
               (null (retrodeck.native:wayland-next-touch))
               (zerop (retrodeck.native:wayland-shutdown-p)))
    (error "Closed Wayland state crossed the native boundary incorrectly"))
  (unless (zerop (retrodeck.native:wayland-present-canvas))
    (error "Closed Wayland canvas presentation succeeded"))
  (unless (zerop (retrodeck.native:wayland-present-solid 0))
    (error "Wayland solid callback did not accept one argument"))
  (unless (= (retrodeck.native:wayland-dispatch 0) -1)
    (error "Wayland dispatch callback did not accept one argument"))
  (retrodeck.native:wayland-close)
  (unless (= (retrodeck.native:play-tones 659 25 0 0 0) 0)
    (error "Invalid audio request crossed the native boundary"))
  (unless (play-menu-sound :confirm 42)
    (error "Native audio worker did not start"))
  (unless (menu-sound-blocks-input-p :controller)
    (error "Controller quarantine was not active"))
  (when (menu-sound-blocks-input-p :touch)
    (error "Menu sound blocked touch"))
  (stop-menu-sound)
  (unless (= (retrodeck.native:audio-active-p) 0)
    (error "Native audio worker did not stop"))
  (finish-menu-sound)
  0)
